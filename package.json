{
  "name": "zoonk",
  "private": true,
  "scripts": {
    "auth:generate": "NEXT_PUBLIC_APP_DOMAIN=localhost:3000 pnpm dlx auth@latest generate --output=./packages/db/src/prisma/models/accounts.prisma --config=./packages/auth/src/auth.ts",
    "build": "turbo build",
    "build:e2e": "turbo build:e2e",
    "db:generate": "turbo db:generate",
    "dev": "turbo dev",
    "e2e": "turbo e2e",
    "evals": "cd apps/evals && pnpm build-and-start",
    "evals:export": "./apps/evals/scripts/export-test-case.sh",
    "evals:remove": "./apps/evals/scripts/remove-test-cases.sh",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "i18n": "pnpm dlx lingo.dev@latest run",
    "i18n:check": "./scripts/i18n.sh",
    "knip": "knip",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix --deny-warnings .",
    "start": "turbo start",
    "stripe:listen": "stripe listen --forward-to http://localhost:4000/v1/auth/stripe/webhook",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "knip": "6.2.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "turbo": "2.9.3"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "pnpm@10.33.0"
}
