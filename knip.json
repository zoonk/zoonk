{
  "$schema": "./node_modules/knip/schema.json",
  "ignore": ["**/*.d.**.ts", ".agents/**", ".claude/**"],
  "ignoreIssues": { "**/.next/**/types/routes.d.ts": ["types"] },
  "ignoreWorkspaces": ["packages/e2e!", "packages/testing!"],
  "ignoreBinaries": ["stripe", "build-and-start", "turbo!"],
  "ignoreDependencies": [
    "@prisma/client",
    "@tailwindcss/postcss",
    "next",
    "postcss-load-config",
    "raw-loader",
    "tsx"
  ],
  "includeEntryExports": true,
  "tags": ["-lintignore", "-internal", "-public"],
  "workspaces": {
    "apps/api": {
      "entry": [".eloqnt/config.ts"],
      "project": ["src/**/*.{ts,tsx}!", "e2e/**/*.ts", "!**/_test-utils/**!"]
    },
    "apps/blog": { "project": ["src/**/*.{ts,tsx}!"] },
    "apps/main": {
      "entry": [".eloqnt/config.ts", "src/app/*/privacy/*.mdx", "src/app/*/terms/*.mdx"],
      "project": ["src/**/*.{ts,tsx}!", "e2e/**/*.ts"]
    },
    "packages/core": { "project": ["src/**/*.ts!"] },
    "packages/db": {
      "entry": ["prisma.config.ts"],
      "ignore": ["src/prisma/seed.ts", "src/prisma/seed/**"],
      "prisma": false
    },
    "packages/player": {
      "entry": [".eloqnt/config.ts"],
      "project": ["src/**/*.{ts,tsx}!", "!**/_test-utils/**!"]
    },
    "packages/ui": { "includeEntryExports": false }
  }
}
