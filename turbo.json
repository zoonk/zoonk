{
  "$schema": "./node_modules/turbo/schema.json",
  "globalEnv": [
    "AI_GATEWAY_API_KEY",
    "AI_MODEL_ACTIVITY_CHALLENGE",
    "AI_MODEL_ACTIVITY_CUSTOM",
    "AI_MODEL_ACTIVITY_DISTRACTORS",
    "AI_MODEL_ACTIVITY_EXPLANATION",
    "AI_MODEL_ACTIVITY_GRAMMAR_USER_CONTENT",
    "AI_MODEL_ACTIVITY_GRAMMAR",
    "AI_MODEL_ACTIVITY_PRACTICE",
    "AI_MODEL_ACTIVITY_PRONUNCIATION",
    "AI_MODEL_ACTIVITY_QUIZ",
    "AI_MODEL_ACTIVITY_ROMANIZATION",
    "AI_MODEL_ACTIVITY_SENTENCES",
    "AI_MODEL_ACTIVITY_VOCABULARY",
    "AI_MODEL_ALTERNATIVE_TITLES",
    "AI_MODEL_CHAPTER_LESSONS",
    "AI_MODEL_COURSE_CATEGORIES",
    "AI_MODEL_COURSE_CHAPTERS",
    "AI_MODEL_COURSE_DESCRIPTION",
    "AI_MODEL_COURSE_SUGGESTIONS",
    "AI_MODEL_LANGUAGE_CHAPTER_LESSONS",
    "AI_MODEL_LANGUAGE_COURSE_CHAPTERS",
    "AI_MODEL_LESSON_ACTIVITIES",
    "AI_MODEL_LESSON_KIND",
    "AI_MODEL_STEP_VISUAL",
    "AI_MODEL_TRANSLATION",
    "APPLE_CLIENT_ID",
    "APPLE_KEY_ID",
    "APPLE_PRIVATE_KEY",
    "APPLE_TEAM_ID",
    "BETTER_AUTH_SECRET",
    "BLOB_READ_WRITE_TOKEN",
    "DATABASE_URL_UNPOOLED",
    "DATABASE_URL",
    "E2E_TESTING",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "HIDDEN_SUBSCRIPTION_PLANS",
    "MAILER_API_KEY",
    "OPENAI_API_KEY",
    "SENTRY_AUTH_TOKEN",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "//#format": {},
    "//#format:fix": { "cache": false },
    "//#lint": {
      "dependsOn": ["@zoonk/db#db:generate"]
    },
    "//#lint:fix": {
      "cache": false,
      "dependsOn": ["@zoonk/db#db:generate"]
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"]
    },
    "build": {
      "dependsOn": ["^db:generate", "^db:deploy", "^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "build:e2e": {
      "dependsOn": ["^db:generate", "^build:e2e"],
      "outputs": [".next-e2e/**", "!.next-e2e/cache/**"]
    },
    "db:deploy": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "dependsOn": ["^db:generate"],
      "outputs": ["src/generated/**"]
    },
    "db:setup:test": {
      "cache": false,
      "dependsOn": ["^db:setup:test"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^db:generate", "^dev"],
      "persistent": true
    },
    "e2e": {
      "passThroughEnv": ["PLAYWRIGHT_*", "E2E_BASE_URL"]
    },
    "start": {
      "cache": false,
      "dependsOn": ["^start"],
      "persistent": true
    },
    "test": {
      "dependsOn": ["^db:generate", "^db:setup:test", "^test"]
    },
    "test:watch": {
      "cache": false,
      "dependsOn": ["^db:generate", "^db:setup:test"],
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^db:generate", "^typecheck"],
      "outputs": [".next/types/**"]
    }
  },
  "ui": "tui"
}
