model Word {
  id             String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetLanguage String              @map("target_language") @db.VarChar(10)
  word           String
  romanization   String?
  audioUrl       String?             @map("audio_url")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at")
  pronunciations WordPronunciation[]
  lessons        LessonWord[]
  steps          Step[]

  @@unique([organizationId, targetLanguage, word], name: "orgWord")
  @@map("words")
}

/// Stores user-language-specific pronunciation guides for words.
/// Pronunciation is a property of the word's sound, not its meaning —
/// "banco" is pronounced the same whether it means "bank" or "bench".
/// But it varies by user language: an English speaker gets "BAHN-koh"
/// while a Portuguese speaker gets a different phonetic guide.
/// That's why pronunciation lives in its own table keyed on
/// (wordId, userLanguage) rather than on `Word` (no user language)
/// or `LessonWord` (would duplicate the same value across lessons).
model WordPronunciation {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  wordId        String   @map("word_id") @db.Uuid
  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  userLanguage  String   @map("user_language") @db.VarChar(10)
  pronunciation String
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([wordId, userLanguage], name: "wordPronunciation")
  @@map("word_pronunciations")
}

model Sentence {
  id             String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetLanguage String           @map("target_language") @db.VarChar(10)
  sentence       String
  romanization   String?
  audioUrl       String?          @map("audio_url")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @default(now()) @updatedAt @map("updated_at")
  lessons        LessonSentence[]
  steps          Step[]

  @@unique([organizationId, targetLanguage, sentence], name: "orgSentence")
  @@map("sentences")
}

/// Links a word to a lesson with its lesson-specific translation.
/// Translations live here instead of a global `WordTranslation` table because
/// the same word can have different meanings in different lessons — e.g.
/// Spanish "banco" means "bank" in a finance lesson but "bench" in a
/// furniture lesson. A global translation would be overwritten by whichever
/// lesson saved last.
model LessonWord {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  lessonId     String   @map("lesson_id") @db.Uuid
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  wordId       String   @map("word_id") @db.Uuid
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  userLanguage String   @map("user_language") @db.VarChar(10)
  translation  String   @default("")
  /// Stores direct target-language distractor words for this lesson word.
  /// These are generated up front so the player can render wrong options
  /// directly instead of deriving them from semantic overlap rules.
  distractors  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([lessonId, wordId], name: "lessonWord")
  @@index([wordId])
  @@map("lesson_words")
}

/// Links a sentence to a lesson with its lesson-specific translation.
/// Follows the same pattern as `LessonWord` — translations are scoped to
/// lessons rather than stored globally. While sentence-level polysemy is
/// rarer than word-level (sentences carry their own context), the design
/// principle is identical: explanation is inherently lesson-context-specific
/// (a grammar lesson explains the same sentence differently than a
/// vocabulary lesson), and fixing the schema pre-launch is far cheaper
/// than migrating production data later.
model LessonSentence {
  id                     String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  lessonId               String   @map("lesson_id") @db.Uuid
  lesson                 Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  sentenceId             String   @map("sentence_id") @db.Uuid
  sentence               Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  userLanguage           String   @map("user_language") @db.VarChar(10)
  translation            String   @default("")
  /// Stores direct target-language distractor words for reading word banks.
  distractors            String[] @default([])
  /// Stores direct user-language distractor words for listening word banks.
  translationDistractors String[] @default([]) @map("translation_distractors")
  explanation            String?
  createdAt              DateTime @default(now()) @map("created_at")

  @@unique([lessonId, sentenceId], name: "lessonSentence")
  @@index([sentenceId])
  @@map("lesson_sentences")
}
