model Lesson {
  id                Int                   @id @default(autoincrement())
  organizationId    String?               @map("organization_id")
  organization      Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chapterId         Int                   @map("chapter_id")
  chapter           Chapter               @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  isLocked          Boolean               @default(false) @map("is_locked")
  isPublished       Boolean               @default(false) @map("is_published")
  language          String                @db.VarChar(10)
  kind              LessonKind            @default(core)
  slug              String
  title             String
  normalizedTitle   String                @map("normalized_title")
  description       String
  concepts          String[]              @default([])
  generationStatus  GenerationStatus      @default(pending) @map("generation_status")
  generationRunId   String?               @map("generation_run_id")
  isRegenerating    Boolean               @default(false) @map("is_regenerating")
  managementMode    ContentManagementMode @default(manual) @map("management_mode")
  generationVersion Int?                  @map("generation_version")
  position          Int
  archivedAt        DateTime?             @map("archived_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at")
  activities        Activity[]
  completions       LessonCompletion[]
  words             LessonWord[]
  sentences         LessonSentence[]

  @@unique([chapterId, slug], name: "chapterLessonSlug")
  @@index([organizationId, archivedAt, normalizedTitle])
  @@index([chapterId, archivedAt, position])
  @@index([organizationId, kind])
  @@map("lessons")
}

model Activity {
  id               BigInt                @id @default(autoincrement())
  organizationId   String?               @map("organization_id")
  organization     Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lessonId         Int                   @map("lesson_id")
  lesson           Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  isPublished      Boolean               @default(false) @map("is_published")
  language         String                @db.VarChar(10)
  kind             ActivityKind          @default(custom)
  title            String?
  description      String?
  generationStatus GenerationStatus      @default(pending) @map("generation_status")
  generationRunId  String?               @map("generation_run_id")
  managementMode   ContentManagementMode @default(manual) @map("management_mode")
  position         Int
  archivedAt       DateTime?             @map("archived_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at")
  steps            Step[]
  progress         ActivityProgress[]

  @@index([lessonId, archivedAt, position])
  @@index([lessonId, archivedAt, generationStatus])
  @@index([organizationId, kind])
  @@map("activities")
}

model Step {
  id          BigInt        @id @default(autoincrement())
  activityId  BigInt        @map("activity_id")
  activity    Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  wordId      BigInt?       @map("word_id")
  word        Word?         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  sentenceId  BigInt?       @map("sentence_id")
  sentence    Sentence?     @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  kind        StepKind
  position    Int
  isPublished Boolean       @default(false) @map("is_published")
  content     Json
  archivedAt  DateTime?     @map("archived_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")
  attempts    StepAttempt[]

  @@index([activityId, archivedAt, position])
  @@index([activityId, kind, archivedAt, position])
  @@index([wordId])
  @@index([sentenceId])
  @@map("steps")
}
