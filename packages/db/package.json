{
  "name": "@zoonk/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./utils": "./src/utils.ts"
  },
  "scripts": {
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:reset:e2e": "env $(cat .env.e2e | xargs) prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:seed:e2e": "env $(cat .env.e2e | xargs) prisma db seed",
    "db:setup:e2e": "env $(cat .env.e2e | xargs) prisma migrate deploy",
    "db:setup:test": "env $(cat .env.test | xargs) prisma migrate deploy",
    "db:studio": "prisma studio",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@vercel/functions": "3.4.3",
    "@zoonk/utils": "workspace:*",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "@typescript/native-preview": "7.0.0-dev.20260312.1",
    "@zoonk/tsconfig": "workspace:*",
    "dotenv": "17.3.1",
    "prisma": "7.5.0",
    "tsx": "4.21.0"
  },
  "peerDependencies": {
    "server-only": ">=0.0.1"
  }
}
