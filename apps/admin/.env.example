# Use the same secret used in the `main` app
BETTER_AUTH_SECRET=

# Database connection URL for Prisma
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/zoonk

# Direct database connection URL for Prisma Migrate
DATABASE_URL_UNPOOLED=

# This app's domain (eg localhost:3200, admin.zoonk.com)
NEXT_PUBLIC_APP_DOMAIN=localhost:3200

# Centralized API App URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel AI Gateway metrics
AI_GATEWAY_API_KEY=

### OPTIONAL VARIABLES ###

# Mailer API key for email services
MAILER_API_KEY=

# Stripe API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
