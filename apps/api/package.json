    "@zoonk/db": "workspace:*",
    "@zoonk/next": "workspace:*",
    "@zoonk/ui": "workspace:*",
    "@zoonk/utils": "workspace:*",
    "botid": "1.5.11",
    "lucide-react": "0.577.0",
    "next": "16.1.6",
    "next-intl": "4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
